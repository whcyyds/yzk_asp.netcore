<Window x:Class="异步不要用sleep_作业.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:异步不要用sleep_作业"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBox  x:Name="input1" HorizontalAlignment="Left" Margin="10,50,0,0" TextWrapping="Wrap" Text="请输入" VerticalAlignment="Top" Height="30" Width="200" IsReadOnly="False"/>
            <Button x:Name="btnStart" Content="开始" HorizontalAlignment="Left" Margin="10,100,0,0" VerticalAlignment="Top" Width="75" Click="btnStart_Click"/>
            <TextBlock  x:Name="txtStatus" HorizontalAlignment="Left" Margin="10,143,0,0" TextWrapping="Wrap" Text="状态" VerticalAlignment="Top" Height="30" Width="200"/>
    </Grid>
</Window>
